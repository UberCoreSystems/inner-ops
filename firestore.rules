
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────
    // Inner Ops Firestore rules
    //
    // Canonical data layout: top-level collections (`journalEntries`,
    // `killTargets`, `relapseEntries`, `hardLessons`,
    // `compassChecks`) where each document carries `userId`. The application
    // ALWAYS queries with `where("userId","==",auth.uid)`; the rules below
    // enforce that shape so unfiltered reads are rejected by the rules
    // engine before they hit data.
    //
    // Pass 2 Finding 1 remediation: `allow list` is owner-gated in the same
    // way `get` is. Firestore evaluates list rules against the query — they
    // must be satisfiable for EVERY document the query could return. The
    // `resource.data.userId == request.auth.uid` check forces the client to
    // include the userId filter; otherwise the query is rejected.
    //
    // Pass 2 Finding 5 remediation: previously this file also defined
    // shadow user-scoped paths under `/users/{uid}/{collection}` that the
    // application code never wrote to. Those duplicates are removed —
    // user data lives at the top level and only at the top level.
    // ─────────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && userId == request.auth.uid;
    }

    function createsOwnDocument() {
      return isSignedIn() &&
        request.resource.data.userId is string &&
        request.resource.data.userId == request.auth.uid;
    }

    function updatesOwnDocument() {
      return isSignedIn() &&
        resource.data.userId is string &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId;
    }

    // Standard owner-gated rule applied to every per-user top-level
    // collection. `list` is satisfiable only when the query constrains by
    // userId — the `resource.data.userId == request.auth.uid` check forces
    // the client to include the `where("userId","==",auth.uid)` filter,
    // otherwise the query is rejected.
    //
    // A `request.query.limit <= 1000` guard was previously included as
    // "defense in depth", but no client query sets a `.limit()`, so
    // `request.query.limit` was unset and CEL evaluated the comparison
    // to false — denying every list. The userId filter is the real
    // scoping mechanism; per-user collections on this app are bounded
    // by user behavior, not by a rule-level cap.
    function ownerListAllowed() {
      return isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

    // ─── Per-user metadata namespace ────────────────────────────────────
    // The /users/{uid} document itself stores user profile/settings.
    // Subcollections live elsewhere (top-level), not here, so this match
    // is intentionally narrow.
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update, delete: if isOwner(userId);
      // Nobody enumerates the users root.
      allow list: if false;

      // Server-managed rate-limit counters. Admin SDK (Cloud Functions)
      // bypasses rules, so it can write here. Clients cannot.
      match /_rateLimits/{docId} {
        allow read, write: if false;
      }

      // Third-party integration tokens (e.g. Oura OAuth). Currently no
      // server-side writer is wired up; this `deny` is defense in depth so
      // that even if a stale client renders the Connect Oura button the
      // OAuth token cannot be persisted client-side. Move to Admin-SDK-only
      // writes when Oura is moved out of post-launch deferred scope.
      match /integrations/{docId} {
        allow read, write: if false;
      }
    }

    // ─── Top-level user-data collections ───────────────────────────────
    match /journalEntries/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    match /killTargets/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }


    match /relapseEntries/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    match /hardLessons/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    match /compassChecks/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    // ─── Feature-sprint collections ────────────────────────────────────

    // BER-243: Kill List confirmed-kills archive
    match /confirmedKills/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    // Pattern Confrontation history. Each doc records one Confront tap (or a
    // manual dismiss) on the Dashboard's PatternConfrontationCard. Powers the
    // 24h dedupe, the inline archive panel, and the Confrontation Rate metric.
    match /confrontations/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    // ─── User-initiated archive collections ────────────────────────────
    // Parallel-collection pattern: each active collection has a sibling
    // `{name}Archive` the user can move entries into. `restoreEntry` moves
    // them back. Hard-delete is only available from the archive view.

    match /journalEntriesArchive/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    match /killTargetsArchive/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    match /hardLessonsArchive/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    match /relapseEntriesArchive/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }


    // EmergencyButton session logging
    match /emergencyLogs/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    // Synthesis briefings — created client-side by generateSynthesisBriefing.js
    // (the rules comment previously claimed CF/Admin-SDK creation, but the
    // actual writer is client-side writeData). Client reads briefings and
    // updates isNew/readAt on open (SynthesisBriefing.jsx:72).
    match /syntheses/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    // Profile settings and synthesis cadence preference
    match /userSettings/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    // User profile — onboarding completion, primary driver, feedback style,
    // confrontation criteria, identity context for Oracle, plus the personal-
    // context fields (activeSituations, keyPeople, knownTriggers,
    // operatingContext) added in BER-onboarding/engagement.
    //
    // Doc-id pattern: the document key IS the user's uid. Authorization is
    // therefore by path parameter, not by a userId field on the data —
    // saveUserProfile() (src/utils/userProfile.js) writes via setDoc with no
    // userId field, so the data-userId-based helpers don't apply here.
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create, update, delete: if isOwner(userId);
      // Profile docs are never enumerated — clients always read by uid.
      allow list: if false;
    }

    // Morning Brief — one document per user per calendar day.
    // Document id format: `{userId}_{YYYY-MM-DD}`. Clients read/write their
    // own briefs; never enumerate across users.
    match /dailyBriefs/{docId} {
      allow create: if createsOwnDocument();
      allow get, delete: if isOwner(resource.data.userId);
      allow update: if updatesOwnDocument();
      allow list: if ownerListAllowed();
    }

    // ─── Subcollections ─────────────────────────────────────────────────

    // Oura Ring biometrics cache — CF writes via Admin SDK; client reads only.
    match /users/{userId}/biometrics/{docId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // ─── Long-term AI memory ────────────────────────────────────────────
    // One doc per module (journal | killList | hardLessons | relapse) plus a
    // `global` synthesis doc, holding date-stamped themes and the user's own
    // verbatim, validated receipts. Written EXCLUSIVELY by Cloud Functions
    // (Admin SDK, scoped to the verified caller's uid): generation, edit, and
    // wipe all route through callables — never a raw client write. Owner reads
    // its own; all client writes denied. This supersedes the earlier client-
    // writable `aiMemory` root stub, which did not satisfy server-only writes.
    match /users/{userId}/memory/{docId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // ─── Default deny (explicit floor) ──────────────────────────────────
    // Firestore already denies any path not matched above, but the explicit
    // catch-all makes the intent un-missable and ensures any collection added
    // in the future is denied until it gets its own owner-scoped match block.
    // Removed `test-connection`: the shipped client never reads/writes it, and
    // "no collection the app doesn't use gets an allow" is the standard. Smoke
    // tests run against the emulator (rules-permissive) or use a real user-data
    // collection, so no production allow is needed for connectivity checks.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
